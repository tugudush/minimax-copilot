{
  "name": "minimax-copilot",
  "displayName": "MiniMax Copilot",
  "description": "MiniMax models in Copilot Chat",
  "version": "0.1.0",
  "publisher": "minimax-copilot-paygo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minimax-copilot-paygo/minimax-copilot-paygo.git"
  },
  "engines": {
    "vscode": "^1.111.0"
  },
  "enabledApiProposals": [
    "languageModelThinkingPart"
  ],
  "categories": [
    "Machine Learning",
    "Chat"
  ],
  "keywords": [
    "minimax",
    "copilot",
    "m3",
    "payg",
    "coding agent",
    "ai",
    "llm"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "walkthroughs": [
      {
        "id": "minimax.setup",
        "title": "Get Started with MiniMax PAYG Copilot",
        "description": "Set up your MiniMax API key, choose your region, and enable adaptive thinking.",
        "steps": [
          {
            "id": "welcome",
            "title": "Welcome",
            "description": "MiniMax M3 in Copilot Chat with a pay‑as‑you‑go key.",
            "media": {
              "markdown": "walkthroughs/setup/welcome.md"
            }
          },
          {
            "id": "setKey",
            "title": "Set API Key",
            "description": "Store your MiniMax PAYG API key securely.",
            "media": {
              "markdown": "walkthroughs/setup/set-key.md"
            },
            "completionEvents": [
              "onCommand:minimax.setApiKey"
            ]
          },
          {
            "id": "chooseRegion",
            "title": "Choose Region",
            "description": "Pick the China or Global endpoint for your account.",
            "media": {
              "markdown": "walkthroughs/setup/choose-region.md"
            }
          },
          {
            "id": "thinking",
            "title": "Adaptive Thinking",
            "description": "M3 reasoning as a collapsible block in Copilot Chat.",
            "media": {
              "markdown": "walkthroughs/setup/thinking.md"
            }
          }
        ]
      }
    ],
    "languageModelProviders": [
      {
        "id": "minimax",
        "vendor": "minimax"
      }
    ],
    "commands": [
      {
        "command": "minimax.setApiKey",
        "title": "MiniMax: Set API Key"
      },
      {
        "command": "minimax.clearApiKey",
        "title": "MiniMax: Clear API Key"
      },
      {
        "command": "minimax.switchToGlobal",
        "title": "MiniMax: Switch to Global API"
      },
      {
        "command": "minimax.switchToChina",
        "title": "MiniMax: Switch to Chinese API"
      },
      {
        "command": "minimax.toggleThinking",
        "title": "MiniMax: Toggle Thinking"
      },
      {
        "command": "minimax.showLogs",
        "title": "MiniMax: Show Logs"
      }
    ],
    "configuration": {
      "title": "MiniMax Copilot (PAYG)",
      "properties": {
        "minimax.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Anthropic-compatible base URL. Auto-picked from locale on first activation; leave blank for the default."
        },
        "minimax.thinking": {
          "type": "boolean",
          "default": true,
          "description": "Enable adaptive reasoning/thinking for MiniMax M3."
        },
        "minimax.visibleModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Model IDs to show in the picker. Empty = all models."
        },
        "minimax.maxOutputTokens": {
          "type": "number",
          "default": 0,
          "description": "Output token cap per request. 0 = model decides."
        },
        "minimax.debugMode": {
          "type": "string",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "default": "minimal",
          "description": "Debug verbosity. 'verbose' writes full request bodies to disk."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ltfb": "npm run lint && npm run typecheck && npm run format && npm run compile",
    "test": "node --import tsx --test test/**/*.test.ts",
    "package": "vsce package"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "prettier": "^3.9.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1"
  }
}
